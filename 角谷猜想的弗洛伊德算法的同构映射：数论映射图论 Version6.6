procedure Tf_Floyd.b_runClick(Sender: TObject);
var
  i, j, k, x, y, steps: integer;
  maxint: integer;
begin
  maxint := 999999;
  m_3n124.Lines.Clear;
  m_3n124.Lines.Add('角谷猜想的弗洛伊德算法同构映射：数论→图论 Version6.6');
  m_3n124.Lines.Add('仅考虑奇数状态，构建最短路径图');

  // 初始化距离矩阵（假设最多100个奇数）
  for i := 0 to 99 do
    for j := 0 to 99 do
      dist[i][j] := maxint;

  // 构建奇数状态转移图
  // 假设我们关注从 7 开始的所有奇数
  var oddList: array[0..10] of integer = (7,11,17,13,5,1);
  var idxMap: array[0..100] of integer; // 映射奇数到索引

  for i := 0 to High(oddList) do
    idxMap[oddList[i]] := i;

  for i := 0 to High(oddList) do begin
    x := oddList[i];
    y := CollatzNextOdd(x); // 3x+1 后不断除以2直到奇数
    steps := CountDiv2(3*x+1); // 即 k
    if idxMap[y] <> -1 then begin
      dist[i][idxMap[y]] := steps + 1; // +1 是因为 3x+1 这一步
    end;
  end;

  // Floyd-Warshall
  for k := 0 to High(oddList) do
    for i := 0 to High(oddList) do
      for j := 0 to High(oddList) do
        if dist[i][k] + dist[k][j] < dist[i][j] then
          dist[i][j] := dist[i][k] + dist[k][j];

  // 输出结果
  m_3n124.Lines.Add('');
  m_3n124.Lines.Add('从各奇数到1的最短路径步数：');
  for i := 0 to High(oddList) do begin
    if dist[i][idxMap[1]] < maxint then
      m_3n124.Lines.Add(Format('%d -> 1: %d 步', [oddList[i], dist[i][idxMap[1]]]))
    else
      m_3n124.Lines.Add(Format('%d -> 1: 无法到达', [oddList[i]]));
  end;
end;
```

