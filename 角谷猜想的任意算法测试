def collatz_binary_steps(n, mode='3n+1'):
    """
    模拟角谷或五谷算法，记录二进制变化特征
    mode: '3n+1' for Collatz, '1n+1' for Wugu
    """
    steps = 0
    max_val = n
    trajectory = [n]
    
    while n != 1:
        if n % 2 == 0:
            n = n // 2
        else:
            if mode == '3n+1':
                n = 3 * n + 1
            elif mode == '1n+1':
                n = n + 1
            # 注意：标准角谷通常合并除以2的步骤，这里为了观察二进制位，
            # 可以选择不立即除尽，或者记录除尽前的状态
        steps += 1
        if n > max_val:
            max_val = n
        trajectory.append(n)
        
    return steps, max_val, trajectory

# 测试对比
